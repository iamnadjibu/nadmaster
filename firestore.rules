rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── NAD MASTER — Personal App Rules ───────────────────────────────────────
    // Single-user anonymous auth app. Each user (NAD) can only access their
    // own data under users/{userId}/...
    // Anonymous Firebase Auth is used — so request.auth != null is sufficient.

    // Helper: is the requester the owner of this document?
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ── User root document ────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // ── Sessions ────────────────────────────────────────────────────────────
      match /sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }

      // ── Goals ───────────────────────────────────────────────────────────────
      match /goals/{goalId} {
        allow read, write: if isOwner(userId);
      }

      // ── Quran Progress ───────────────────────────────────────────────────────
      match /quranProgress/{docId} {
        allow read, write: if isOwner(userId);
      }

      // ── Surah Tracking ───────────────────────────────────────────────────────
      match /surahTracking/{surahNumber} {
        allow read, write: if isOwner(userId);
      }

      // ── Daily Performance ────────────────────────────────────────────────────
      match /performance/{date} {
        allow read, write: if isOwner(userId);
      }

      // ── Weekly Reports ───────────────────────────────────────────────────────
      match /weeklyReports/{weekId} {
        allow read, write: if isOwner(userId);
      }

      // ── Profile ──────────────────────────────────────────────────────────────
      match /profile/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // All other paths are denied by default
  }
}
